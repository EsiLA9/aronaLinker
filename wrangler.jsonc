{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "arona-linker",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-12",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "none",
    "run_worker_first": true
  }
}
